          { "type": "text", "text": "Quantico", "italic": true },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "Code Black", "italic": true },
          { "type": "text", "text": ", and " },
          { "type": "text", "text": "Intelligence", "italic": true },
          { "type": "text", "text": ". He is the creator, showrunner, and executive producer of " },
          { "type": "text", "text": "The Rainmaker", "italic": true },
          {
            "type": "text",
            "text": ", USA Network's adaptation of the John Grisham novel, which was renewed for a second season in 2025."
