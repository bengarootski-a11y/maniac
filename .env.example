# TinaCMS — set these in Vercel (Project → Settings → Environment Variables)
# and locally in a .env file (gitignored).

# Public client ID from your Tina Cloud project.
NEXT_PUBLIC_TINA_CLIENT_ID=ed8a7d48-5905-4e55-a6b4-00b217e440c7

# Read/write token generated in Tina Cloud (Project → Tokens). Keep it secret.
TINA_TOKEN=

# Branch Tina reads/writes content from. Optional — on Vercel it falls back to
# the deployed branch automatically. Set to your production branch (e.g. main).
NEXT_PUBLIC_TINA_BRANCH=main
